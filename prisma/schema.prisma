generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Post {
  id        String  @id @default(cuid())
  title     String
  content   String?
  published Boolean @default(false)
}

model Category {
  id              String       @id @default(cuid())
  name            String
  type            CategoryType
  parentCategory  Category?    @relation("ChildCategories", fields: [parentId], references: [id])
  parentId        String?
  childCategories Category[]   @relation("ChildCategories")
  products        Product[]
}

enum CategoryType {
  PRIMARY
  SECONDARY
  TERTIARY
  QUATERNARY
}

model Product {
  id               String    @id @default(cuid())
  name             String
  description      String?
  model            String?
  type             String?
  warranty         String?
  guarantee        String?
  tradePrice       Float?
  contractPrice    Float?
  promotionalPrice Float?
  unit             String?
  weight           Float?
  color            String?
  length           Float?
  width            Float?
  height           Float?
  material         String?
  templateId       String?
  template         Template? @relation(fields: [templateId], references: [id])
  features         Feature[]
  category         Category  @relation(fields: [categoryId], references: [id])
  categoryId       String
  brand            Brand?    @relation(fields: [brandId], references: [id])
  brandId          String?
  status           Status    @default(DRAFT)
  manuals          String[]
  images           Image[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String
  products Product[]
}

model Feature {
  id        String  @id @default(cuid())
  name      String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum Status {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Image {
  id          String  @id @default(cuid())
  url         String
  description String?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
}

model Template {
  id          String    @id @default(cuid())
  name        String
  description String?
  fields      Json[]
  products    Product[]
}

enum FieldType {
  TEXT
  SELECT
}

